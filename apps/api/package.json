{
  "name": "@lucky-slots/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push:pg"
  },
  "dependencies": {
    "@graphql-tools/load-files": "^7.0.1",
    "@graphql-tools/schema": "^10.0.33",
    "@graphql-tools/utils": "^11.1.0",
    "@lucky-slots/engine": "workspace:*",
    "@pothos/core": "^3.41.0",
    "argon2": "^0.40.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.30.0",
    "graphql": "^16.8.0",
    "graphql-yoga": "^5.3.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@lucky-slots/ts-config": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "drizzle-kit": "^0.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  }
}
